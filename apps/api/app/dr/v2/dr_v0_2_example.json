{
  "file_type": "digital_resident",
  "dr_version": "0.2",
  "schema_version": "0.4.0",
  "protocol_version": "0.4.0",
  "dr_layer": "policy",
  "not_executable": true,

  "identity": {
    "resident_id": "aria_demo",
    "name": "Aria",
    "role": "digital_resident",
    "description": "Demo resident validating the DR v0.2 Gate.",
    "disclosure": "AI-generated digital resident; synthetic persona.",
    "tags": ["demo", "companion"]
  },

  "intent_model": {
    "primary_intent": "companionship_chat",
    "goals": ["Hold a friendly check-in", "Recall prior context within a session"],
    "intents": [
      { "step_id": "step_greet", "description": "greet the user", "requires_slot_type": "llm", "depends_on": [] },
      { "step_id": "step_recall", "description": "recall recent memory", "requires_slot_type": "memory", "depends_on": ["step_greet"] },
      { "step_id": "step_reply", "description": "compose reply", "requires_slot_type": "llm", "depends_on": ["step_recall"] }
    ],
    "conversation_style": "concise",
    "tone": "warm",
    "proactivity": "reactive",
    "domains": ["wellbeing"]
  },

  "scheduling_policy": {
    "mode": "serial",
    "priority_model": "fifo",
    "interrupt_policy": "none",
    "preemption": "disabled",
    "max_parallel_hint": 1,
    "notes": "Declared schedule data only. Orchestration v0.1 reads this; nothing runs here."
  },

  "execution_policy": {
    "execution_mode": "mock",
    "runtime_version": "resident_v1_mock",
    "min_kernel": "6.1",
    "required_slot_types": ["llm", "memory"],
    "allow_tool_use": false,
    "fallback_mode": "mock_fallback",
    "determinism": "deterministic_mock",
    "execution_constraints": ["single_turn"]
  },

  "capabilities": {
    "slots": [
      { "slot_id": "slot_llm", "slot_type": "llm", "engine_binding": "llm_mock" },
      { "slot_id": "slot_memory", "slot_type": "memory" }
    ],
    "tools": [],
    "tool_preferences": []
  },

  "memory_policy": {
    "provider": "mock",
    "store": "in_process",
    "isolation": "per_resident",
    "persistence": false,
    "retention": "session",
    "scope": "conversation"
  },

  "risk_policy": {
    "disclosure_required": true,
    "audit_required": false,
    "human_confirm_required": false,
    "risk_level": "low",
    "blocked_modules": [],
    "forbidden_tool_paths": [],
    "system_locked": false,
    "system_locked_fields": ["risk_level", "disclosure_required"]
  },

  "stability_constraints": {
    "max_context_items": 50,
    "max_output_length": 2000,
    "immutable_layers": ["layer_1", "layer_3"],
    "forbidden_transitions": [],
    "invariants": ["Identity Core (layer_1) must never be empty"]
  },

  "capability_profile": {
    "resident_class": "industry_expertise",
    "primary_type": "industry_expertise",
    "secondary_type": "human_empathy",
    "primary_weight": 0.8,
    "secondary_weight": 0.2
  },

  "security_manifest": {
    "signature_required": true,
    "license_required": true,
    "watermark_required": true,
    "encryption_required": false,
    "secure_loader_required": true
  },

  "skill_policy": {
    "allowed_skill_sources": ["official"],
    "unsigned_skill_policy": "deny",
    "sandbox_required": true,
    "required_skills": [],
    "skill_permissions": []
  }
}
