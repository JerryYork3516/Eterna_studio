{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eterna.studio/schemas/digital_resident_v0_2.json",
  "title": "Digital Resident v0.2 (Behavior Policy Spec)",
  "description": "POLICY LAYER, NOT RUNTIME LAYER. A declarative description of a schedulable persona. Every field is configuration data only. Reading a DR must never execute, schedule, or orchestrate anything. scheduling_policy is parsed by Orchestration; it is not a scheduler.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "file_type",
    "dr_version",
    "dr_layer",
    "not_executable",
    "identity",
    "intent_model",
    "scheduling_policy",
    "execution_policy",
    "capabilities",
    "memory_policy",
    "risk_policy",
    "stability_constraints"
  ],
  "properties": {
    "file_type": { "const": "digital_resident" },
    "dr_version": { "type": "string", "const": "0.2" },
    "schema_version": { "type": "string" },
    "protocol_version": { "type": "string" },
    "dr_layer": {
      "type": "string",
      "const": "policy",
      "description": "Machine-readable marker: DR lives in the policy layer, never the runtime layer."
    },
    "not_executable": {
      "type": "boolean",
      "const": true,
      "description": "A DR never runs. It is read by Orchestration as input."
    },

    "identity": {
      "type": "object",
      "additionalProperties": true,
      "required": ["resident_id"],
      "properties": {
        "resident_id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "description": { "type": ["string", "null"] },
        "disclosure": { "type": "string" },
        "persona_summary": { "type": ["string", "null"] },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },

    "intent_model": {
      "type": "object",
      "additionalProperties": true,
      "description": "What the resident is for. Declared goals/style; no behavior.",
      "properties": {
        "primary_intent": { "type": "string" },
        "goals": { "type": "array", "items": { "type": "string" } },
        "conversation_style": { "type": ["string", "null"] },
        "tone": { "type": ["string", "null"] },
        "proactivity": { "type": "string", "enum": ["passive", "reactive", "proactive"] },
        "domains": { "type": "array", "items": { "type": "string" } }
      }
    },

    "scheduling_policy": {
      "type": "object",
      "additionalProperties": true,
      "description": "Read ONLY by Orchestration to plan. Pure data; triggers nothing. Not a scheduler.",
      "properties": {
        "schedulable": { "type": "boolean" },
        "trigger_modes": {
          "type": "array",
          "items": { "type": "string", "enum": ["on_message", "on_event", "on_schedule"] }
        },
        "priority": { "type": "string", "enum": ["low", "normal", "high"] },
        "concurrency_hint": { "type": "integer", "minimum": 0, "description": "Hint for an orchestrator; not a concurrency mechanism." },
        "cadence": {
          "type": "object",
          "additionalProperties": true,
          "description": "Schedule descriptor. Describes a cadence; never runs one.",
          "properties": {
            "type": { "type": "string", "enum": ["none", "interval", "cron"] },
            "value": { "type": ["string", "null"] }
          }
        },
        "max_turns_per_session": { "type": ["integer", "null"] },
        "cooldown_seconds": { "type": ["integer", "null"] },
        "notes": { "type": ["string", "null"] }
      }
    },

    "execution_policy": {
      "type": "object",
      "additionalProperties": true,
      "description": "How an orchestrator SHOULD treat the resident. Declaration, not execution. No retry/DAG/concurrency.",
      "properties": {
        "execution_mode": { "type": "string", "enum": ["mock"] },
        "runtime_version": { "type": "string" },
        "min_kernel": { "type": "string" },
        "required_slot_types": { "type": "array", "items": { "type": "string" } },
        "engines": { "type": "array", "items": { "type": "object" } },
        "allow_tool_use": { "type": "boolean" },
        "determinism": { "type": "string" },
        "timeout_hint_seconds": { "type": ["integer", "null"] },
        "on_error_preference": { "type": "string", "enum": ["mock_fallback", "halt", "skip"] }
      }
    },

    "capabilities": {
      "type": "object",
      "additionalProperties": true,
      "description": "What the resident is declared able to use. Declarations, never invoked.",
      "properties": {
        "modules": { "type": "array", "items": { "type": "object" } },
        "slots": { "type": "array", "items": { "type": "object" } },
        "declared_capabilities": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["id"],
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string" },
              "name": { "type": ["string", "null"] },
              "slot_type": { "type": ["string", "null"] },
              "layer_id": { "type": ["string", "null"] },
              "status": { "type": ["string", "null"] }
            }
          }
        }
      }
    },

    "memory_policy": {
      "type": "object",
      "additionalProperties": true,
      "description": "Declared memory configuration. No memory engine, no I/O.",
      "properties": {
        "provider": { "type": "string" },
        "store": { "type": "string" },
        "isolation": { "type": "string" },
        "persistence": { "type": "boolean" },
        "retention": { "type": ["string", "null"] },
        "scope": { "type": ["string", "null"] }
      }
    },

    "risk_policy": {
      "type": "object",
      "additionalProperties": true,
      "description": "Declared safety/governance posture. Declarations only.",
      "properties": {
        "disclosure_required": { "type": "boolean" },
        "audit_required": { "type": "boolean" },
        "human_confirm_required": { "type": "boolean" },
        "risk_level": { "type": "string", "enum": ["none", "low", "medium", "high", "critical"] },
        "blocked_modules": { "type": "array", "items": { "type": "string" } },
        "safety_boundaries": { "type": "array", "items": { "type": "string" } }
      }
    },

    "stability_constraints": {
      "type": "object",
      "additionalProperties": true,
      "description": "Invariants an orchestrator MUST respect. Declared limits; not enforced here.",
      "properties": {
        "max_context_items": { "type": ["integer", "null"] },
        "max_output_length": { "type": ["integer", "null"] },
        "immutable_layers": { "type": "array", "items": { "type": "string" } },
        "forbidden_transitions": { "type": "array", "items": { "type": "string" } },
        "invariants": { "type": "array", "items": { "type": "string" } }
      }
    },

    "resident": { "type": ["object", "null"], "description": "v0.1 compatibility field (preserved)." },
    "layers": { "type": ["array", "null"], "description": "v0.1 compatibility field (preserved)." },
    "modules": { "type": ["array", "null"], "description": "v0.1 compatibility field (preserved)." },
    "slots": { "type": ["array", "null"], "description": "v0.1 compatibility field (preserved)." },
    "runtime_requirements": { "type": ["object", "null"], "description": "v0.1 compatibility field (preserved)." },
    "memory_config": { "type": ["object", "null"], "description": "v0.1 compatibility field (preserved)." },
    "safety_policy": { "type": ["object", "null"], "description": "v0.1 compatibility field (preserved)." },
    "audit": { "type": ["object", "null"], "description": "v0.1 compatibility field (preserved)." },
    "compile_info": { "type": ["object", "null"], "description": "v0.1 compatibility field (preserved)." }
  }
}
